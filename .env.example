# Sentinel — env contract. Copy to .env and fill what each dispatch needs.
# Only ANTHROPIC_API_KEY + TAVILY_API_KEY are required at boot. Every other
# key may be blank: the service it gates is silently disabled until present.

# ── inference ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
PREMIUM_MODEL=claude-sonnet-4-6

# Cheap tier — defaults to the Anthropic OpenAI-compatibility endpoint with
# Haiku 4.5 (the stand-in we shipped at Receipts). D02 swaps these three for
# Pioneer's OpenAI-compatible endpoint + model.
CHEAP_BASE_URL=
CHEAP_API_KEY=
CHEAP_MODEL=

# Pioneer (D02 — adaptive cheap tier + feedback loop).
# All three required for cheap-direct-Pioneer (S1 fallback); blank → falls
# back to D00 stand-in. PIONEER_BASE_URL example: https://api.pioneer.ai/v1
PIONEER_API_KEY=
PIONEER_BASE_URL=
PIONEER_MODEL=
# Exact path that Pioneer publishes for adaptive feedback / inference-history
# POSTs. Blank → record_feedback() no-ops. Get the path from the rep / docs;
# the dispatch's "don't guess the URL" guard means we don't ship a default.
PIONEER_FEEDBACK_URL=
# Optional per-MTok overrides for Pioneer cost (defaults to the imputed
# CHEAP_* rates so the dashboard surfaces a non-zero cost out of the box).
PIONEER_INPUT_PER_MTOK=
PIONEER_OUTPUT_PER_MTOK=

# TrueFoundry AI Gateway (D01 — route both tiers through gateway).
# All four required for TF routing; blank → falls back to direct Anthropic.
# Model IDs come from TF's snippet generator in "provider-account/model" form,
# e.g. anthropic-main/claude-sonnet-4-6.
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_BASE_URL=
TF_MODEL_CHEAP=
TF_MODEL_PREMIUM=

# ── evidence ─────────────────────────────────────────────────────────────────
TAVILY_API_KEY=
TAVILY_API_KEY_BACKUP=

# ── publish / pay / act / store ──────────────────────────────────────────────
# Senso / cited.md (D04)
SENSO_API_KEY=

# x402 paywall (D05)
# Buyer-facing price per verdict fetch once the endpoint is paywalled.
X402_PAY_TO=
X402_PRICE_USD=0.01

# Composio (D09)
COMPOSIO_API_KEY=

# Thesys C1 / OpenUI (D10)
THESYS_C1_API_KEY=

# ClickHouse (D08)
CLICKHOUSE_URL=
CLICKHOUSE_PASSWORD=

# ── sentinel loop (D03) ──────────────────────────────────────────────────────
WATCH_INTERVAL_S=30

# ── flags ────────────────────────────────────────────────────────────────────
# Magnific honest-ad stage. Magnific is not a sponsor at this hack; OFF.
HONEST_AD_ENABLED=false

# ── run knobs (cascade tuning — same as Receipts) ────────────────────────────
N_VENDORS=10
SEMAPHORE=8
JUDGE_CONFIDENCE_THRESHOLD=0.7
SCRAPE_TIMEOUT_S=10
LLM_TIMEOUT_S=45
CHEAP_LLM_TIMEOUT_S=8

# Cheap-tier sponsor/vendor pricing used only for dashboard spend estimates.
# Values are USD per million tokens plus a per-attempt floor. Keep these in
# sync with the sponsor's current pricing sheet when swapping providers.
CHEAP_INPUT_PER_MTOK=0.05
CHEAP_OUTPUT_PER_MTOK=0.10
CHEAP_ATTEMPT_COST_USD=0.0002
